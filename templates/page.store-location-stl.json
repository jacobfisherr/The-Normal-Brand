        "column_Rmmpbx": {
          "type": "column",
          "settings": {
            "title": "Exclusive Events",
            "text": "<p>Who doesn't love a good ol'fashioned get together? We frequently partner with other brands/influencers to host events that will add to your TNB experience.</p>",
            "liquid": "",
            "link_label": "",
