        "column_THiJQ9": {
          "type": "column",
          "settings": {
            "title": "TNB Hospitality",
            "text": "<p>We know the importance of a solid retail experience here at The Normal Brand, which is why we do everything we can to ensure you walk away happy & satisfied!</p>",
            "liquid": "",
            "link_label": "",
            "link": "",
            "text_alignment": "left",
