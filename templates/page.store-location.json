    "multicolumn_ExbEyA": {
      "type": "multicolumn",
      "blocks": {
        "column_Rmmpbx": {
          "type": "column",
          "settings": {
            "title": "Exclusive Events",
            "text": "<p>Who doesn't love a good ol'fashioned get together? We frequently partner with other brands/influencers to host events that will add to your TNB experience.</p>",
            "liquid": "",
            "link_label": "",
            "link": "",
            "text_alignment": "left",
            "text_alignment_mobile": "left"
          }
        },
        "column_THiJQ9": {
          "type": "column",
          "settings": {
            "title": "TNB Hospitality",
            "text": "<p>We know the importance of a solid retail experience here at The Normal Brand, which is why we do everything we can to ensure you walk away happy & satisfied!</p>",
            "liquid": "",
            "link_label": "",
            "link": "",
            "text_alignment": "left",
            "text_alignment_mobile": "left"
          }
        },
        "column_CrF7Gb": {
          "type": "column",
          "settings": {
            "title": "Follow For More",
            "text": "<p>Checkout all the deals and exclusive events on our instagram! Follow us @thenormalbrand and be sure to give our city stores a follow!</p>",
            "liquid": "",
            "link_label": "",
            "link": "",
            "text_alignment": "left",
            "text_alignment_mobile": "left"
          }
        }
      },
