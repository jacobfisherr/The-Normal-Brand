{% doc %}
  @prompt
    A featured product block that is the size of a single product card on PLP
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-product-card-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  .ai-featured-product-card__inner-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_corner_radius }}px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    transition: transform 0.3s ease;
  }

  .ai-featured-product-card__inner-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-featured-product-card__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 125%;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-featured-product-card__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-product-card__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-featured-product-card__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-featured-product-card__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    padding: 6px 12px;
    background-color: {{ block.settings.badge_bg_color }};
    color: {{ block.settings.badge_text_color }};
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    border-radius: {{ block.settings.badge_corner_radius }}px;
    letter-spacing: 0.5px;
  }

  .ai-featured-product-card__content-{{ ai_gen_id }} {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex-grow: 1;
  }

  .ai-featured-product-card__vendor-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0;
  }

  .ai-featured-product-card__title-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 500;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .ai-featured-product-card__price-{{ ai_gen_id }} {
    font-size: 16px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-top: auto;
  }

  .ai-featured-product-card__price--sale-{{ ai_gen_id }} {
    color: {{ block.settings.sale_price_color }};
  }

  .ai-featured-product-card__compare-price-{{ ai_gen_id }} {
    font-size: 14px;
    text-decoration: line-through;
    opacity: 0.6;
    margin-right: 8px;
  }

  .ai-featured-product-card__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    background-color: rgba(255, 255, 255, 0.9);
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-featured-product-card__content-{{ ai_gen_id }} {
      padding: 12px;
    }

    .ai-featured-product-card__title-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-featured-product-card__price-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<featured-product-card-{{ ai_gen_id }} class="ai-featured-product-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.featured_product != blank %}
    {% assign product = block.settings.featured_product %}
    <a href="{{ product.url }}" class="ai-featured-product-card__inner-{{ ai_gen_id }}">
      <div class="ai-featured-product-card__image-wrapper-{{ ai_gen_id }}">
        {% if product.featured_image %}
          <img
            src="{{ product.featured_image | image_url: width: 600 }}"
            alt="{{ product.featured_image.alt | escape }}"
            class="ai-featured-product-card__image-{{ ai_gen_id }}"
            loading="lazy"
            width="600"
            height="750"
          >
        {% else %}
          <div class="ai-featured-product-card__placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.show_badge and product.compare_at_price > product.price %}
          <div class="ai-featured-product-card__badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </div>
        {% endif %}
      </div>

      <div class="ai-featured-product-card__content-{{ ai_gen_id }}">
        {% if block.settings.show_vendor and product.vendor != blank %}
          <p class="ai-featured-product-card__vendor-{{ ai_gen_id }}">{{ product.vendor }}</p>
        {% endif %}

        <h3 class="ai-featured-product-card__title-{{ ai_gen_id }}">{{ product.title }}</h3>

        <div class="ai-featured-product-card__price-{{ ai_gen_id }} {% if product.compare_at_price > product.price %}ai-featured-product-card__price--sale-{{ ai_gen_id }}{% endif %}">
          {% if product.compare_at_price > product.price %}
            <span class="ai-featured-product-card__compare-price-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
          {% endif %}
          {{ product.price | money }}
        </div>
      </div>
    </a>
  {% else %}
    <div class="ai-featured-product-card__inner-{{ ai_gen_id }}">
      <div class="ai-featured-product-card__image-wrapper-{{ ai_gen_id }}">
        <div class="ai-featured-product-card__placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
        <div class="ai-featured-product-card__empty-state-{{ ai_gen_id }}">
          Select a product to feature
        </div>
      </div>

      <div class="ai-featured-product-card__content-{{ ai_gen_id }}">
        <h3 class="ai-featured-product-card__title-{{ ai_gen_id }}">Product title</h3>
        <div class="ai-featured-product-card__price-{{ ai_gen_id }}">$0.00</div>
      </div>
    </div>
  {% endif %}
</featured-product-card-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedProductCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('featured-product-card-{{ ai_gen_id }}', FeaturedProductCard{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Featured product card",
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "featured_product",
      "label": "Product"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show sale badge",
      "default": true
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Sale"
    },
    {
      "type": "color",
      "id": "badge_bg_color",
      "label": "Badge background",
      "default": "#ef612e"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "badge_corner_radius",
      "label": "Badge corner radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 4
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#22242a"
    },
    {
      "type": "color",
      "id": "sale_price_color",
      "label": "Sale price",
      "default": "#ef612e"
    },
    {
      "type": "range",
      "id": "card_corner_radius",
      "label": "Corner radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Featured product card"
    }
  ]
}
{% endschema %}
